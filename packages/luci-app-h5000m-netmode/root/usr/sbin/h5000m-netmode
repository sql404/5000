#!/bin/sh

mode="$(uci -q get h5000m_netmode.settings.mode || echo wan_first)"

print_status() {
	local wan_metric wan6_metric usb_metric usbv6_metric qmodem_metric
	local wan_defaultroute wan6_defaultroute usb_defaultroute usbv6_defaultroute
	local default4 default6 active4 active6

	wan_metric="$(uci -q get network.wan.metric || echo "")"
	wan6_metric="$(uci -q get network.wan6.metric || echo "")"
	usb_metric="$(uci -q get network.USB.metric || echo "")"
	usbv6_metric="$(uci -q get network.USBv6.metric || echo "")"
	wan_defaultroute="$(uci -q get network.wan.defaultroute || echo 1)"
	wan6_defaultroute="$(uci -q get network.wan6.defaultroute || echo 1)"
	usb_defaultroute="$(uci -q get network.USB.defaultroute || echo 1)"
	usbv6_defaultroute="$(uci -q get network.USBv6.defaultroute || echo 1)"
	qmodem_metric=''
	for modem in $(uci -q show qmodem | sed -n 's/^\(qmodem\.[^.]*\)=modem-device$/\1/p'); do
		qmodem_metric="$(uci -q get "${modem}.metric" || echo "")"
		[ -n "${qmodem_metric}" ] && break
	done
	default4="$(ip route show default 2>/dev/null | head -n 1)"
	default6="$(ip -6 route show default 2>/dev/null | head -n 1)"

	case "${default4}" in
		*' dev eth1 '*|*' dev wan '*)
			active4='wan'
			;;
		*' dev eth2 '*|*' dev USB '*)
			active4='USB'
			;;
		*)
			active4=''
			;;
	esac

	case "${default6}" in
		*' dev eth1 '*|*' dev wan6 '*)
			active6='wan6'
			;;
		*' dev eth2 '*|*' dev USBv6 '*)
			active6='USBv6'
			;;
		*)
			active6=''
			;;
	esac

	echo "mode=${mode}"
	echo "wan_metric=${wan_metric}"
	echo "wan6_metric=${wan6_metric}"
	echo "usb_metric=${usb_metric}"
	echo "usbv6_metric=${usbv6_metric}"
	echo "wan_defaultroute=${wan_defaultroute}"
	echo "wan6_defaultroute=${wan6_defaultroute}"
	echo "usb_defaultroute=${usb_defaultroute}"
	echo "usbv6_defaultroute=${usbv6_defaultroute}"
	echo "qmodem_metric=${qmodem_metric}"
	echo "active4=${active4}"
	echo "active6=${active6}"
	echo "default4=${default4}"
	echo "default6=${default6}"
}

if [ "${1:-}" = "status" ]; then
	print_status
	exit 0
fi

case "${mode}" in
	modem_first)
		wan_metric='50'
		modem_metric='10'
		wan_defaultroute='1'
		modem_defaultroute='1'
		usbv6_defaultroute='1'
		;;
	wan_only)
		wan_metric='10'
		modem_metric='50'
		wan_defaultroute='1'
		modem_defaultroute='0'
		usbv6_defaultroute='0'
		;;
	modem_only)
		wan_metric='50'
		modem_metric='10'
		wan_defaultroute='0'
		modem_defaultroute='1'
		usbv6_defaultroute='1'
		;;
	*)
		mode='wan_first'
		wan_metric='10'
		modem_metric='50'
		wan_defaultroute='1'
		modem_defaultroute='1'
		usbv6_defaultroute='1'
		;;
esac

uci -q set h5000m_netmode.settings='settings'
uci -q set h5000m_netmode.settings.mode="${mode}"
uci -q commit h5000m_netmode

uci -q set network.wan.metric="${wan_metric}"
uci -q set network.wan6.metric="${wan_metric}"
uci -q set network.USB.metric="${modem_metric}"
uci -q set network.USBv6.metric="${modem_metric}"
uci -q set network.wan.defaultroute="${wan_defaultroute}"
uci -q set network.wan6.defaultroute="${wan_defaultroute}"
uci -q set network.USB.defaultroute="${modem_defaultroute}"
uci -q set network.USBv6.defaultroute="${usbv6_defaultroute}"
uci -q delete network.wan5g
uci -q delete network.wan5g6
uci -q commit network

for modem in $(uci -q show qmodem | sed -n 's/^\(qmodem\.[^.]*\)=modem-device$/\1/p'); do
	uci -q set "${modem}.metric=${modem_metric}"
done
uci -q commit qmodem

if [ "${1:-}" = "apply" ]; then
	/etc/init.d/network reload >/dev/null 2>&1 || true
	/etc/init.d/qmodem restart >/dev/null 2>&1 || true
fi

exit 0
